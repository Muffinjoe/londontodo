generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Auth
// ──────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  hashedPassword String?
  role           Role      @default(EDITOR)
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  articles       Article[]
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
}

// ──────────────────────────────────────────
// Content
// ──────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?   // hex accent colour for UI
  icon        String?   // lucide icon name
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
  events      Event[]
}

model Area {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  heroImage   String?
  latitude    Float?
  longitude   Float?
  metaTitle   String?
  metaDesc    String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
  events      Event[]
  venues      Venue[]
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  slug     String       @unique
  articles ArticleTag[]
  events   EventTag[]
}

// ──────────────────────────────────────────
// Articles
// ──────────────────────────────────────────

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  kicker          String?       // category label above headline
  subtitle        String?       @db.Text
  excerpt         String?       @db.Text
  body            String        @db.Text
  featureImage    String?
  featureImageAlt String?
  author          User?         @relation(fields: [authorId], references: [id])
  authorId        String?
  category        Category?     @relation(fields: [categoryId], references: [id])
  categoryId      String?
  area            Area?         @relation(fields: [areaId], references: [id])
  areaId          String?
  tags            ArticleTag[]
  status          ContentStatus @default(DRAFT)
  featured        Boolean       @default(false)
  sponsored       Boolean       @default(false)
  sponsorName     String?
  publishedAt     DateTime?
  scheduledAt     DateTime?
  metaTitle       String?
  metaDescription String?       @db.Text
  ogImage         String?
  canonicalUrl    String?
  readingTime     Int?          // minutes
  aiGenerated     Boolean       @default(false)
  aiTemplate      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([areaId])
  @@index([featured])
}

model ArticleTag {
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([articleId, tagId])
}

// ──────────────────────────────────────────
// Events
// ──────────────────────────────────────────

model Event {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String        @db.Text
  shortSummary    String?       @db.Text
  whyGo           String?       @db.Text
  worthItIf       String?       @db.Text
  featureImage    String?
  featureImageAlt String?
  gallery         String[]      // array of image URLs
  category        Category?     @relation(fields: [categoryId], references: [id])
  categoryId      String?
  area            Area?         @relation(fields: [areaId], references: [id])
  areaId          String?
  venue           Venue?        @relation(fields: [venueId], references: [id])
  venueId         String?
  tags            EventTag[]
  startDate       DateTime
  endDate         DateTime?
  startTime       String?       // "19:00"
  endTime         String?       // "23:00"
  recurring       Boolean       @default(false)
  recurrenceRule  String?       // e.g. "every Saturday"
  priceType       PriceType     @default(PAID)
  priceMin        Float?
  priceMax        Float?
  priceCurrency   String        @default("GBP")
  ticketUrl       String?
  websiteUrl      String?
  status          ContentStatus @default(DRAFT)
  featured        Boolean       @default(false)
  sponsored       Boolean       @default(false)
  sponsorName     String?
  familyFriendly  Boolean       @default(false)
  isDaytime       Boolean       @default(true)
  isNightlife     Boolean       @default(false)
  metaTitle       String?
  metaDescription String?       @db.Text
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, startDate])
  @@index([categoryId])
  @@index([areaId])
  @@index([featured])
}

model EventTag {
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId   String

  @@id([eventId, tagId])
}

enum PriceType {
  FREE
  PAID
  DONATION
}

enum ContentStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

// ──────────────────────────────────────────
// Venues
// ──────────────────────────────────────────

model Venue {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  address     String?
  postcode    String?
  latitude    Float?
  longitude   Float?
  websiteUrl  String?
  phone       String?
  heroImage   String?
  area        Area?    @relation(fields: [areaId], references: [id])
  areaId      String?
  events      Event[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ──────────────────────────────────────────
// AI Content Queue
// ──────────────────────────────────────────

model AiDraft {
  id         String      @id @default(cuid())
  template   String      // template name
  topic      String
  inputs     Json?       // structured input data
  output     String?     @db.Text // generated content
  status     DraftStatus @default(PENDING)
  articleId  String?     // linked article if promoted
  reviewNote String?     @db.Text
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum DraftStatus {
  PENDING
  GENERATING
  READY
  APPROVED
  REJECTED
  PUBLISHED
}

// ──────────────────────────────────────────
// Newsletter
// ──────────────────────────────────────────

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
}
